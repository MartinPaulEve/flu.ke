# Keep the build context tiny — source is bind-mounted at runtime, deps come from
# pyproject.toml + uv.lock. Never ship the 30 GB archive or local artifacts.
Ingest/
.venv/
dist/
media/
*.sqlite3
.git/
.github/
__pycache__/
**/__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.staticcollect/
node_modules/
.env
# Env files (real secrets) and their templates — supplied at run time instead.
.env.*
# Tests aren't needed in the runtime image.
tests/
# Local virtualenv variants and editor/OS cruft.
venv/
.DS_Store
