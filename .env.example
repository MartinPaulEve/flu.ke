# Copy to .env and fill in. Never commit .env.
# Generate a key with: uv run python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# SQLite is the database for both local editing and production.
DATABASE_URL=sqlite:///db.sqlite3

# Public site canonical origin (used for absolute URLs, OG images, sitemap, feed)
SITE_BASE_URL=https://flu.ke
SITE_NAME=Fluke

# Where uploaded media lives
MEDIA_ROOT=media

# MusicBrainz requires a descriptive contact User-Agent
MUSICBRAINZ_APP=flukecms
MUSICBRAINZ_VERSION=1.0
MUSICBRAINZ_CONTACT=martin@eve.gd

# Docker dev (compose.yaml): host port to publish the CMS on (the container
# always uses 8000 internally). Change this if 8000 is taken on your machine.
CMS_PORT=8000

# Docker dev: set a password to auto-create the admin on first start; otherwise
# run `docker compose exec cms python manage.py createsuperuser`.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=martin@eve.gd
# DJANGO_SUPERUSER_PASSWORD=change-me

# Production (Docker + Traefik, SQLite): see docs/deploy-docker.md and .env.prod.example.
