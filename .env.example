# Copy to .env and fill in. Never commit .env.
# Generate a key with: uv run python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# SQLite by default (local single-editor CMS). Override for Postgres if desired.
DATABASE_URL=sqlite:///db.sqlite3

# Public site canonical origin (used for absolute URLs, OG images, sitemap, feed)
SITE_BASE_URL=https://flu.ke
SITE_NAME=Fluke

# Where the static build is written, and where uploaded media lives
BUILD_DIR=dist
MEDIA_ROOT=media

# MusicBrainz requires a descriptive contact User-Agent
MUSICBRAINZ_APP=flukecms
MUSICBRAINZ_VERSION=1.0
MUSICBRAINZ_CONTACT=martin@eve.gd

# --- Hosting the CMS on a public web server (e.g. Reclaim) -------------------
# See docs/deploy-reclaim.md. On the server set, instead of the dev values above:
#   DJANGO_DEBUG=False
#   DJANGO_SECURE=True                       # HTTPS redirect + secure cookies + HSTS
#   DJANGO_ALLOWED_HOSTS=cms.flu.ke
#   CSRF_TRUSTED_ORIGINS=https://cms.flu.ke
#   BUILD_DIR=/home/<user>/public_html       # the flu.ke document root (absolute)
#   MEDIA_ROOT=/home/<user>/public_html/media # media served by the public site
#   MEDIA_URL=https://flu.ke/media/          # absolute, so admin previews resolve
#   DATABASE_URL=sqlite:////home/<user>/cms_app/db.sqlite3   # private, outside any docroot

# Docker (compose.yaml). Set a password to auto-create the admin on first start;
# otherwise run `docker compose exec cms python manage.py createsuperuser`.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=martin@eve.gd
# DJANGO_SUPERUSER_PASSWORD=change-me

# Deployment (used by scripts/deploy.sh). Pick one target.
DEPLOY_TARGET=rsync            # rsync | s3 | rclone
DEPLOY_BUILD=1                 # build before deploying
# rsync (to an nginx box):
DEPLOY_RSYNC_DEST=deploy@flu.ke:/var/www/flu.ke
# s3 / R2 / B2:
# DEPLOY_S3_BUCKET=s3://flu.ke
# AWS_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com
# rclone:
# DEPLOY_RCLONE_REMOTE=r2:flu-ke
