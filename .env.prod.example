# Production environment for compose.prod.yaml. Copy to .env.prod and fill in.
# NEVER commit .env.prod — it holds real secrets.
#
#   cp .env.prod.example .env.prod
#   # edit values
#   docker compose -f compose.prod.yaml --env-file .env.prod up -d --build
#
# These feed config.settings_production (DEBUG=False). Secrets come from this
# environment — they are never baked into the image. See docs/deploy-docker.md.

# REQUIRED. Generate a fresh one (do not reuse the dev key):
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-generate-with-secrets-token_urlsafe-50

# SQLite inside the container at /data, which is the bind-mounted $DATA_DIR/db
# host directory (path must stay in sync with the volume mount in
# compose.prod.yaml). The -wal/-shm files live alongside it.
DATABASE_URL=sqlite:////data/db.sqlite3

# Host directory holding the persistent data (SQLite DB + media), bind-mounted
# into the container. MUST live OUTSIDE the git checkout. Recommend an absolute
# path, e.g. /srv/fluke-data. Defaults to ../fluke-data (a sibling of the repo).
# Bind mounts keep the HOST dir's ownership, so create and chown the subdirs to
# the container UID/GID (1000:1000 by default) BEFORE the first `up`:
#   mkdir -p "$DATA_DIR"/db "$DATA_DIR"/media
#   sudo chown -R 1000:1000 "$DATA_DIR"
DATA_DIR=/srv/fluke-data

# Shared Traefik discovery. TLS + routing are handled by a separate, shared
# Traefik instance that finds this container by label (and terminates TLS at its
# own entrypoint). Set these to match that Traefik: the Docker network it watches
# (must already exist) and the HTTPS entrypoint name. (Or edit the labels in
# compose.prod.yaml directly.)
TRAEFIK_NETWORK=traefik
TRAEFIK_ENTRYPOINT=websecure

# Canonical origin (absolute URLs, OG images, sitemap, feed).
SITE_NAME=Fluke
SITE_BASE_URL=https://fluke.fm

# Optional. Hostnames Django will accept, and origins trusted for CSRF. The
# Traefik router already gates traffic by Host(); these make Django's own
# host/CSRF checks accept the same names. Comma-separated.
# DJANGO_ALLOWED_HOSTS=fluke.fm,www.fluke.fm
# CSRF_TRUSTED_ORIGINS=https://fluke.fm,https://www.fluke.fm

# MusicBrainz requires a descriptive contact User-Agent.
MUSICBRAINZ_CONTACT=martin@eve.gd

# Match the container user to whoever owns the bind-mounted $DATA_DIR files on
# the host (override at build: see compose.prod.yaml). Defaults to 1000:1000.
# Whatever you set here, chown $DATA_DIR to the same UID/GID before the first up.
# UID=1000
# GID=1000

# Optional one-shot admin creation by the entrypoint. Prefer creating the admin
# with a one-off `docker compose -f compose.prod.yaml run --rm ... web true`
# rather than leaving a password in the long-running service environment.
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_EMAIL=martin@eve.gd
# DJANGO_SUPERUSER_PASSWORD=change-me
